{
  "name": "curo",
  "version": "0.1.0",
  "description": "App de escritorio para gestión de pacientes y consultas (uso interno doctor)",
  "main": "dist/main/main.js",
  "scripts": {
    "postinstall": "electron-rebuild",
    "dev": "npm run build:main && concurrently \"npm run build:main -- --watch\" \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "node scripts/build-app-icon.mjs && npm run build:main && vite build",
    "build:icon": "node scripts/build-app-icon.mjs",
    "build:main": "tsc -p tsconfig.main.json",
    "preview": "vite preview",
    "start": "electron ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "electron-log": "^5.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
